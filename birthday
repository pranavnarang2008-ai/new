    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        heading: ['var(--font-heading-name)', 'serif'],
                        body: ['var(--font-body-name)', 'sans-serif'],
                        script: ['Dancing Script', 'cursive'],
                    },
                    colors: {
                        rose: {
                            50: '#fdf2f4',
                            100: '#fce7eb',
                            200: '#fad0d9',
                            300: '#f7aab9',
                            400: '#f27a93',
                            500: '#e65273',
                            600: '#d12e55',
                            700: '#b02142',
                            800: '#911d38',
                            900: '#7a1b32',
                        },
                        champagne: {
                            50: '#fbf8f3',
                            100: '#f7f0e6',
                            200: '#ede0cc',
                            300: '#e3cba3',
                            400: '#d9b37a',
                            500: '#cf9c54',
                            600: '#b57f41',
                            700: '#916135',
                            800: '#754d2f',
                            900: '#61402a',
                        }
                    },
                    spacing: {
                        base: 'var(--space-base)',
                    },
                    borderRadius: {
                        small: 'var(--radius-small)',
                        large: 'var(--radius-large)',
                    },
                    boxShadow: {
                        custom: 'var(--shadow-custom)',
                        'custom-hover': 'var(--shadow-custom-hover)',
                        'soft': '0 10px 40px -10px rgba(201, 116, 138, 0.15)',
                        'glow': '0 0 20px rgba(232, 196, 106, 0.4)',
                    },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'shimmer': 'shimmer 2.5s linear infinite',
                        'fade-in-up': 'fadeInUp 0.5s ease-out forwards',
                        'spin-slow': 'spin 3s linear infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-20px)' },
                        },
                        shimmer: {
                            '0%': { backgroundPosition: '-1000px 0' },
                            '100%': { backgroundPosition: '1000px 0' },
                        },
                        fadeInUp: {
                            '0%': { opacity: '0', transform: 'translateY(20px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        }
                    }
                }
            }
        }
    </script>

    <style>
        :root {
            /* Typography */
            --font-heading-name: 'Playfair Display';
            --font-body-name: 'DM Sans';
            --font-heading: 'Playfair Display', serif;
            --font-body: 'DM Sans', sans-serif;
            --letter-spacing-heading: -0.02em;
            --letter-spacing-body: 0px;
            
            /* Spacing */
            --space-base: 1rem;
            
            /* Borders */
            --radius-small: 8px;
            --radius-large: 24px;
            --border-width: 1px;
            
            /* Shadows */
            --shadow-color: 201 116 138;
            --shadow-offset-x: 0px;
            --shadow-offset-y: 8px;
            --shadow-blur: 24px;
            --shadow-spread: -4px;
            --shadow-opacity: 0.15;
            --shadow-custom: 0px 8px 24px -4px rgba(var(--shadow-color), var(--shadow-opacity));
            --shadow-custom-hover: 0px 12px 32px -4px rgba(var(--shadow-color), 0.25);
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #FDF6EC;
        }
        ::-webkit-scrollbar-thumb {
            background: #C9748A;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #b02142;
        }

        html {
            scroll-behavior: smooth;
        }

        .reveal-on-scroll {
            opacity: 0;
            transform: translateY(30px);
            transition: all 1s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .reveal-on-scroll.is-visible {
            opacity: 1;
            transform: translateY(0);
        }

        .polaroid-tilt-1 { transform: rotate(-2deg); }
        .polaroid-tilt-2 { transform: rotate(3deg); }
        .polaroid-tilt-3 { transform: rotate(-1.5deg); }
        
        .text-gradient-gold {
            background: linear-gradient(135deg, #E8C46A 0%, #C9748A 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Photo Frame Styles */
        .photo-frame {
            position: relative;
            background: white;
            padding: 1rem;
            padding-bottom: 3.5rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .photo-frame:hover {
            transform: scale(1.02) rotate(1deg);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            z-index: 10;
        }
        .photo-frame::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border: 1px solid rgba(0,0,0,0.05);
            pointer-events: none;
        }

        /* Loading Overlay */
        .loading-overlay {
            position: absolute;
            inset: 0;
            background: rgba(255, 255, 255, 0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 20;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }
        .loading-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

        /* Toast Notification */
        #toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 100;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .toast {
            background: white;
            border-left: 4px solid #C9748A;
            padding: 16px 24px;
            border-radius: 8px;
            box-shadow: 0 10px 30px -5px rgba(0,0,0,0.1);
            transform: translateX(100%);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 300px;
        }
        .toast.show {
            transform: translateX(0);
        }
        
        /* Hide scrollbar for gallery on mobile */
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>
<body class="font-body bg-[#FDF6EC] text-neutral-800 overflow-x-hidden" style="height: auto; min-height: 100%;">

