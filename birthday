    <script>
        // ==========================================
        // FIREBASE CONFIGURATION - REPLACE THIS!
        // ==========================================
        // 1. Go to https://console.firebase.google.com/
        // 2. Create a new project (it's free)
        // 3. Enable "Firestore Database" and "Storage" in the console
        // 4. In Project Settings, scroll down to "Your apps" and select Web (</>)
        // 5. Copy the config object and paste it below:
        
        const firebaseConfig = {
            apiKey: "YOUR_API_KEY_HERE",
            authDomain: "YOUR_PROJECT_ID.firebaseapp.com",
            projectId: "YOUR_PROJECT_ID",
            storageBucket: "YOUR_PROJECT_ID.appspot.com",
            messagingSenderId: "YOUR_SENDER_ID",
            appId: "YOUR_APP_ID"
        };

        // Initialize Firebase
        let db, storage;
        let isFirebaseConfigured = false;

        try {
            if (firebaseConfig.apiKey !== "YOUR_API_KEY_HERE") {
                firebase.initializeApp(firebaseConfig);
                db = firebase.firestore();
                storage = firebase.storage();
                isFirebaseConfigured = true;
                console.log("Firebase initialized successfully");
            } else {
                console.warn("Firebase config is missing. Using local preview mode.");
            }
        } catch (error) {
            console.error("Error initializing Firebase:", error);
        }

        // Initialize Lucide Icons
        lucide.createIcons();

        // Toast Notification System
        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = 'toast';
            
            const icon = type === 'success' ? 'check-circle' : 'alert-circle';
            const color = type === 'success' ? '#10B981' : '#EF4444';
            
            toast.innerHTML = `
                <i data-lucide="${icon}" style="color: ${color}; width: 24px; height: 24px;"></i>
                <span class="font-medium text-neutral-800">${message}</span>
            `;
            
            container.appendChild(toast);
            lucide.createIcons();
            
            // Trigger animation
            requestAnimationFrame(() => {
                toast.classList.add('show');
            });

            // Remove after 3 seconds
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => {
                    toast.remove();
                }, 300);
            }, 3000);
        }

        // Trigger File Input
        function triggerUpload(inputId) {
            document.getElementById(inputId).click();
        }

        // Handle File Upload (Local + Firebase)
        async function handleFileUpload(event, imgId, loaderId, frameId) {
            const file = event.target.files[0];
            if (!file) return;

            // 1. Show Local Preview Immediately (Optimistic UI)
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById(imgId).src = e.target.result;
            }
            reader.readAsDataURL(file);

            // 2. If Firebase is configured, upload and save
            if (isFirebaseConfigured) {
                const loader = document.getElementById(loaderId);
                loader.classList.add('active');
                
                try {
                    // Create a reference to the file location
                    const storageRef = storage.ref(`birthday_photos/${frameId}_${Date.now()}`);
                    
                    // Upload file
                    await storageRef.put(file);
                    
                    // Get download URL
                    const downloadURL = await storageRef.getDownloadURL();
                    
                    // Save URL to Firestore
                    // We use a single document 'gallery' in collection 'photos' to store all frame URLs
                    await db.collection('photos').doc('gallery').set({
                        [frameId]: downloadURL
                    }, { merge: true });

                    showToast('Photo saved for everyone to see! 🎉');
                } catch (error) {
                    console.error("Upload failed:", error);
                    showToast('Failed to save photo online.', 'error');
                } finally {
                    loader.classList.remove('active');
                }
            } else {
                showToast('Preview only (Firebase not configured)', 'info');
            }
        }

        // Load Saved Photos on Startup
        window.addEventListener('DOMContentLoaded', async () => {
            if (isFirebaseConfigured) {
                try {
                    const doc = await db.collection('photos').doc('gallery').get();
                    if (doc.exists) {
                        const data = doc.data();
                        
                        // Update images if they exist in database
                        if (data.frame_1) document.getElementById('img-1').src = data.frame_1;
                        if (data.frame_2) document.getElementById('img-2').src = data.frame_2;
                        if (data.frame_3) document.getElementById('img-3').src = data.frame_3;
                        if (data.frame_4) document.getElementById('img-4').src = data.frame_4;
                    }
                } catch (error) {
                    console.error("Error loading photos:", error);
                }
            }
        });

        // Toggle Reasons Functionality
        function toggleReasons() {
            const moreReasons = document.getElementById('more-reasons');
            const btnText = document.getElementById('reasons-btn-text');
            const btnIcon = document.getElementById('reasons-icon');
            
            if (moreReasons.classList.contains('hidden')) {
                moreReasons.classList.remove('hidden');
                btnText.innerText = "Show less";
                btnIcon.setAttribute('data-lucide', 'arrow-up');
                lucide.createIcons();
            } else {
                moreReasons.classList.add('hidden');
                btnText.innerText = "Read all 18 reasons";
                btnIcon.setAttribute('data-lucide', 'arrow-down');
                lucide.createIcons();
                document.getElementById('reasons').scrollIntoView({ behavior: 'smooth' });
            }
        }

        // Confetti Animation
        function triggerConfetti() {
            var duration = 3 * 1000;
            var animationEnd = Date.now() + duration;
            var defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 100 };

            function random(min, max) {
                return Math.random() * (max - min) + min;
            }

            var interval = setInterval(function() {
                var timeLeft = animationEnd - Date.now();

                if (timeLeft <= 0) {
                    return clearInterval(interval);
                }

                var particleCount = 50 * (timeLeft / duration);
                var colors = ['#C9748A', '#E8C46A', '#F7E7CE', '#FDF6EC'];

                confetti(Object.assign({}, defaults, { 
                    particleCount, 
                    origin: { x: random(0.1, 0.3), y: Math.random() - 0.2 },
                    colors: colors
                }));
                confetti(Object.assign({}, defaults, { 
                    particleCount, 
                    origin: { x: random(0.7, 0.9), y: Math.random() - 0.2 },
                    colors: colors
                }));
            }, 250);
        }

        // Intersection Observer for Scroll Animations
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    if (entry.target.querySelector('.counter')) {
                        startCounters(entry.target);
                    }
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        document.querySelectorAll('.reveal-on-scroll').forEach((element) => {
            observer.observe(element);
        });

        // Number Counter Animation (Count Up)
        function startCounters(parent) {
            const counters = parent.querySelectorAll('.counter');
            counters.forEach(counter => {
                const target = +counter.getAttribute('data-target');
                const duration = 2000; 
                const increment = target / (duration / 16); 
                
                let current = 0;
                const updateCounter = () => {
                    current += increment;
                    if (current < target) {
                        counter.innerText = Math.ceil(current);
                        requestAnimationFrame(updateCounter);
                    } else {
                        counter.innerText = target;
                    }
                };
                updateCounter();
            });
        }

        // Live Seconds Ticker
        function startSecondsTicker() {
            const secondsElement = document.getElementById('seconds-counter');
            let seconds = 0;
            setInterval(() => {
                seconds++;
                const now = new Date();
                secondsElement.innerText = now.getSeconds().toString().padStart(2, '0');
            }, 1000);
        }
        startSecondsTicker();

        // Navbar Scroll Effect
        window.addEventListener('scroll', () => {
            const navbar = document.getElementById('navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('shadow-sm');
                navbar.classList.replace('bg-[#FDF6EC]/80', 'bg-white/90');
            } else {
                navbar.classList.remove('shadow-sm');
                navbar.classList.replace('bg-white/90', 'bg-[#FDF6EC]/80');
            }
        });
    </script>
